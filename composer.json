{
    "name": "falconandrea/laravel-boilerplate-cli",
    "description": "Interactive CLI to bootstrap and configure Laravel projects.",
    "keywords": ["laravel", "cli", "boilerplate", "installer"],
    "homepage": "https://github.com/falconandrea/laravel-ai-boilerplate",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrea Falcon"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^12.0.2"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["boilerplate"]
}
